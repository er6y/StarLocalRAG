<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="默认模型下载"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- 嵌入模型列表 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="嵌入模型列表"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="0dp" />

        <CheckBox
            android:id="@+id/checkBoxBgeM3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="bge-m3_dynamic_int8_onnx"
            android:layout_marginBottom="0dp" />

        <!-- 重排模型列表 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="重排模型列表"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="0dp" />

        <CheckBox
            android:id="@+id/checkBoxBgeReranker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="bge-reranker-v2-m3_dynamic_int8_onnx"
            android:layout_marginBottom="0dp" />

        <!-- LLM列表 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LLM列表"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="0dp" />

        <CheckBox
            android:id="@+id/checkBoxQwen06B"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Qwen3-0.6B-GGUF"
            android:layout_marginBottom="0dp" />

        <CheckBox
            android:id="@+id/checkBoxQwen17B"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Qwen3-1.7B-GGUF"
            android:layout_marginBottom="0dp" />

        <!-- 进度显示区域 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="下载进度"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="0dp" />

        <TextView
            android:id="@+id/textViewProgress"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@android:color/black"
            android:textColor="@android:color/white"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:padding="8dp"
            android:scrollbars="vertical"
            android:text="等待下载..."
            android:textIsSelectable="true"
            android:longClickable="true"
            android:layout_marginBottom="2dp" />

        <!-- 下载按钮 -->
        <Button
            android:id="@+id/buttonDownload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="下载选中的模型"
            android:layout_marginBottom="2dp" />

        <!-- 最佳实践文本 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="最佳实践说明"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="词嵌入和重排模型采用ONNX Runtime推理，获得最佳广泛模型支持，需要ONNX格式，需要有对应的模型配置文件和tokenizer文件，用户可单独放在设置对应的目录下。注意知识库生成和RAG需要采用一致的模型。\n\n本地LLM推理采用llama.cpp结构的LLM，需要GGUF格式，推荐需要有对应的params文件，用户可单独放在设置对应的目录下。由于手机算力内存有限制，最大勉强支持4B左右的模型。体验较好的是2B以下的模型。本地LLM能力孱弱，效果不佳，可作为学习研究使用。实用性推荐在线大模型。\n\n详细参见帮助"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>